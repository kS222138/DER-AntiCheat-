extends Node
class_name DERReportExporter

signal export_completed(file_path, format)
signal export_failed(format, error)

var export_timer = Timer.new()
var auto_export_enabled = false
var auto_export_interval = 3600
var auto_export_format = "html"
var data_source = null

func _ready():
	add_child(export_timer)
	export_timer.timeout.connect(_on_auto_export)
	export_timer.one_shot = false

func set_data_source(source):
	data_source = source

func enable_auto_export(interval_seconds = 3600, format = "html"):
	auto_export_enabled = true
	auto_export_interval = interval_seconds
	auto_export_format = format
	export_timer.start(interval_seconds)

func disable_auto_export():
	auto_export_enabled = false
	export_timer.stop()

func export_report(format = "json", file_path = ""):
	var valid_formats = ["json", "csv", "html"]
	if format not in valid_formats:
		emit_signal("export_failed", format, "Unsupported format")
		return
	if not data_source:
		emit_signal("export_failed", format, "No data source set")
		return
	var data = _collect_report_data()
	if file_path.is_empty():
		var timestamp = Time.get_datetime_string_from_system().replace(":", "-")
		file_path = "user://anticheat_report_" + timestamp + "." + format
	match format:
		"json": _export_json(data, file_path)
		"csv": _export_csv(data, file_path)
		"html": _export_html(data, file_path)

func _collect_report_data():
	var threat_stats = {}
	var health_score = 100
	var history_trend = []
	var alert_logs = []
	if data_source != null:
		if data_source.has_method("get_threat_stats"):
			threat_stats = data_source.get_threat_stats()
		else:
			threat_stats = _get_default_stats()
		if data_source.has_method("get_health_score"):
			health_score = data_source.get_health_score()
		if data_source.has_method("get_history_trend"):
			history_trend = data_source.get_history_trend()
		if data_source.has_method("get_alert_logs"):
			alert_logs = data_source.get_alert_logs()
	return {
		"timestamp": Time.get_datetime_string_from_system(),
		"threat_stats": threat_stats,
		"health_score": health_score,
		"history_trend": history_trend,
		"alert_logs": alert_logs
	}

func _get_default_stats():
	return {"total": 0, "critical": 0, "high": 0, "warning": 0, "info": 0}

func _export_json(data, file_path):
	var file = FileAccess.open(file_path, FileAccess.WRITE)
	if file:
		file.store_string(JSON.stringify(data, "\t"))
		file.close()
		emit_signal("export_completed", file_path, "json")
	else:
		emit_signal("export_failed", "json", "Failed to write file")

func _export_csv(data, file_path):
	var file = FileAccess.open(file_path, FileAccess.WRITE)
	if not file:
		emit_signal("export_failed", "csv", "Failed to write file")
		return
	var stats = data["threat_stats"]
	file.store_line("Report Timestamp," + data["timestamp"])
	file.store_line("Health Score," + str(data["health_score"]))
	file.store_line("")
	file.store_line("Threat Statistics")
	file.store_line("Total," + str(stats.get("total", 0)))
	file.store_line("Critical," + str(stats.get("critical", 0)))
	file.store_line("High," + str(stats.get("high", 0)))
	file.store_line("Warning," + str(stats.get("warning", 0)))
	file.store_line("Info," + str(stats.get("info", 0)))
	file.store_line("")
	if data["history_trend"].size() > 0:
		file.store_line("History Trend (Last " + str(data["history_trend"].size()) + " points)")
		var header = "Index"
		for i in range(data["history_trend"].size()):
			header += ",Point_" + str(i + 1)
		file.store_line(header)
		var values = "Threat_Count"
		for point in data["history_trend"]:
			values += "," + str(point)
		file.store_line(values)
		file.store_line("")
	if data["alert_logs"].size() > 0:
		file.store_line("Alert Logs (Last " + str(data["alert_logs"].size()) + ")")
		file.store_line("Timestamp,Severity,Message")
		for log in data["alert_logs"]:
			file.store_line(log.get("timestamp", "") + "," + log.get("severity", "") + "," + log.get("message", ""))
	file.close()
	emit_signal("export_completed", file_path, "csv")

func _export_html(data, file_path):
	var stats = data["threat_stats"]
	var health = data["health_score"]
	var history = data["history_trend"]
	var logs = data["alert_logs"]
	var health_color = "#27ae60"
	if health < 80: health_color = "#f39c12"
	if health < 60: health_color = "#e67e22"
	if health < 40: health_color = "#e74c3c"
	
	var html = "<!DOCTYPE html><html><head><meta charset='UTF-8'><title>AntiCheat Report</title>"
	html += "<style>body{font-family:sans-serif;margin:20px;background:#f5f5f5;color:#333;}"
	html += ".container{max-width:1200px;margin:0 auto;background:#fff;border-radius:8px;padding:20px;}"
	html += "h1{color:#2c3e50;border-bottom:3px solid #3498db;}"
	html += ".stats-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));gap:15px;margin:20px 0;}"
	html += ".stat-card{background:#f8f9fa;border-radius:8px;padding:15px;text-align:center;border-left:4px solid #3498db;}"
	html += ".critical{border-left-color:#e74c3c;}.high{border-left-color:#e67e22;}.warning{border-left-color:#f39c12;}"
	html += ".stat-number{font-size:32px;font-weight:bold;margin:10px 0;}"
	html += ".health-score{text-align:center;margin:30px 0;padding:20px;background:#f8f9fa;border-radius:8px;}"
	html += ".score-value{font-size:48px;font-weight:bold;color:" + health_color + ";}"
	html += "table{width:100%;border-collapse:collapse;}th,td{padding:10px;text-align:left;border-bottom:1px solid #ddd;}"
	html += "th{background:#3498db;color:#fff;}.footer{text-align:center;margin-top:30px;padding-top:20px;border-top:1px solid #ddd;color:#7f8c8d;font-size:12px;}"
	html += "</style>"
	html += "<script src='https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js'></script>"
	html += "</head><body><div class='container'><h1>AntiCheat Report</h1>"
	html += "<p><strong>Generated:</strong> " + data["timestamp"] + "</p>"
	html += "<div class='stats-grid'>"
	html += "<div class='stat-card'><h3>Total</h3><div class='stat-number'>" + str(stats.get("total", 0)) + "</div></div>"
	html += "<div class='stat-card critical'><h3>Critical</h3><div class='stat-number'>" + str(stats.get("critical", 0)) + "</div></div>"
	html += "<div class='stat-card high'><h3>High</h3><div class='stat-number'>" + str(stats.get("high", 0)) + "</div></div>"
	html += "<div class='stat-card warning'><h3>Warning</h3><div class='stat-number'>" + str(stats.get("warning", 0)) + "</div></div>"
	html += "<div class='stat-card'><h3>Info</h3><div class='stat-number'>" + str(stats.get("info", 0)) + "</div></div>"
	html += "</div><div class='health-score'><h2>Health Score</h2><div class='score-value'>" + str(health) + "/100</div></div>"
	
	if history.size() > 0:
		html += "<div class='chart-container'><h2>Threat Trend</h2><canvas id='trendChart'></canvas></div>"
		html += "<script>new Chart(document.getElementById('trendChart'),{type:'line',data:{labels:Array.from({length:" + str(history.size()) + "},(_,i)=>i+1),datasets:[{label:'Threat Count',data:" + JSON.stringify(history) + ",borderColor:'#e74c3c',backgroundColor:'rgba(231,76,60,0.1)',tension:0.4,fill:true}]},options:{responsive:true,scales:{y:{beginAtZero:true}}}});</script>"
	
	if logs.size() > 0:
		html += "<h2>Recent Alerts</h2><table><thead><tr><th>Time</th><th>Level</th><th>Message</th></tr></thead><tbody>"
		for log in logs:
			var sev = log.get("severity", "info")
			var cls = ""
			if sev == "critical": cls = " style='color:#e74c3c;font-weight:bold'"
			elif sev == "high": cls = " style='color:#e67e22;font-weight:bold'"
			elif sev == "warning": cls = " style='color:#f39c12'"
			html += "<tr><td>" + log.get("timestamp", "") + "</td><td" + cls + ">" + sev.to_upper() + "</td><td>" + log.get("message", "") + "</td></tr>"
		html += "</tbody></table>"
	
	html += "<div class='footer'>Generated by DER AntiCheat v1.8.0<br>" + Time.get_datetime_string_from_system() + "</div></div></body></html>"
	
	var file = FileAccess.open(file_path, FileAccess.WRITE)
	if file:
		file.store_string(html)
		file.close()
		emit_signal("export_completed", file_path, "html")
	else:
		emit_signal("export_failed", "html", "Failed to write file")

func _get_health_color(score):
	if score >= 80: return "#27ae60"
	if score >= 60: return "#f39c12"
	if score >= 40: return "#e67e22"
	return "#e74c3c"

func _on_auto_export():
	if auto_export_enabled and data_source != null:
		export_report(auto_export_format)